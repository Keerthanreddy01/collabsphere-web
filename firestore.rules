rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    function validEmail(email) {
      return email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    function notTooLong(text, maxLen) {
      return text.size() <= maxLen;
    }

    // POSTS
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth()
        && isOwner(request.resource.data.uid)
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() < 2000;
      allow update: if isOwner(resource.data.uid)
        && !request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasAny(['uid', 'created_at', 'author_username']);
      allow delete: if isOwner(resource.data.uid);
    }

    // COMMENTS subcollection
    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isAuth()
        && isOwner(request.resource.data.author_uid)
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() < 500;
      allow delete: if isAuth() && 
        isOwner(resource.data.author_uid);
    }

    // BUILDER PROFILES
    match /builder_profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data)
           .affectedKeys().hasAny(['uid', 'created_at']);
      allow delete: if false;
    }

    // APP WAITLIST
    match /app_waitlist/{docId} {
      // SECURITY: read is intentionally false — email addresses are PII.
      // Reads must go through the backend using Firebase Admin SDK,
      // which bypasses these client-side rules entirely.
      // TEMPORARY FIX: Allowed read for development because admin SDK is not configured
      allow read: if true;
      allow create: if 
        request.resource.data.email is string
        && validEmail(request.resource.data.email)
        && request.resource.data.platform in 
           ['android', 'ios', 'both']
        && request.resource.data.keys().hasAll([
             'email', 'platform', 'joined_at',
             'position', 'ref_code'
           ]);
      allow update, delete: if false;
    }

    // MESSAGES (subcollection: messages/{conversationId}/messages/{messageId})
    match /messages/{conversationId}/messages/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && isOwner(request.resource.data.senderId)
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 1000;
      // SECURITY: update restricted to the message sender only.
      // Previously `if isAuth()` allowed ANY authenticated user to tamper
      // with any message — this closes that gap.
      allow update: if isAuth() && isOwner(resource.data.senderId);
      allow delete: if false;
    }

    // CONVERSATIONS
    match /conversations/{convId} {
      allow read: if isAuth() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuth() &&
        request.auth.uid in 
        request.resource.data.participants;
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;
    }

    // PROJECTS
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAuth()
        && isOwner(request.resource.data.owner_uid);
      allow update: if isAuth()
        && isOwner(resource.data.owner_uid);
      allow delete: if isAuth()
        && isOwner(resource.data.owner_uid);
    }

    // AUTH EVENTS - read only
    match /auth_events/{eventId} {
      allow read: if isAuth() && 
        resource.data.uid == request.auth.uid;
      allow create: if isAuth()
        && isOwner(request.resource.data.uid);
      allow update, delete: if false;
    }

    // SPACES
    match /spaces/{spaceId} {
      allow read: if true;
      // Allow authenticated users to create/update spaces for now
      allow write: if isAuth();
    }

    // BLOCK EVERYTHING ELSE
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
