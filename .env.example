# ─────────────────────────────────────────────────────────────────────────────
# CollabSphere — Root .env.example
#
# This monorepo uses TWO separate .env files:
#   • frontend/.env.local      ← Next.js client (copy from frontend/.env.example)
#   • backend/.env             ← Express API  (copy from backend/.env.example)
#
# Do NOT put real secrets here. This file is committed and public.
# See each subfolder's .env.example for the full variable list.
# ─────────────────────────────────────────────────────────────────────────────

# ─── FRONTEND (frontend/.env.local) ──────────────────────────────────────────
# Firebase Web SDK (safe to expose — prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Backend API base URL (no trailing slash)
# Local dev: http://localhost:5000
# Production: https://your-api.example.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── BACKEND (backend/.env) ──────────────────────────────────────────────────
# Server
PORT=5000
NODE_ENV=development

# Firebase Admin SDK (server-only — NEVER expose to client)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# CORS — allowed frontend origin
FRONTEND_URL=http://localhost:3000
